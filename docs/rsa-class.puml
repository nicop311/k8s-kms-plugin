@startuml
!pragma layout smetana

package k8s-kms-plugin {

struct P11 implements Service {
}

interface Service
Service : \*EncryptResponse Encrypt(Context, *EncryptRequest)
Service : \*DecryptResponse Decrypt(Context, *DecryptRequest)

struct P11
P11 : []byte kid
P11 : []byte cid
P11 : \*crypto11.Config config
P11 : \*crypto11.Context ctx
P11 : map[string]gose.JweEncryptor encryptors
P11 : map[string]gose.JweDecryptor decryptors
P11 : bool createKey
P11 : string k8sDefaultDekLabel
P11 : string k8sHmacKeyLabel
P11 : jose.Alg algorithm
P11 : \*EncryptResponse Encrypt(Context, *EncryptRequest)
P11 : \*DecryptResponse Decrypt(Context, *DecryptRequest)

note right of P11::algorithm
define which type of encryptor (cbc, gcm, rsa) will be called
end note

}


package gose {

package "crypto" {

class rsa
rsa : EncryptOAEP(hash hash.Hash, random io.Reader, pub *PublicKey, msg []byte, label []byte) ([]byte, error)
}

struct JweRsaKeyEncryptionEncryptorImpl implements JweEncryptor {
}

struct JweRsaKeyEncryptionDecryptorImpl implements JweDecryptor {
}

struct AsymmetricDecryptionKeyImpl implements AsymmetricDecryptionKey {
}

interface JweEncryptor
JweEncryptor : string Encrypt(plaintext, aad []byte)

interface JweDecryptor
JweDecryptor : (plaintext, aad []byte) Decrypt(jwe string)

interface AsymmetricDecryptionKey
AsymmetricDecryptionKey : Key
AsymmetricDecryptionKey : Algorithmed
AsymmetricDecryptionKey : Decrypt(jose.KeyOps, []byte) ([]byte, error)
AsymmetricDecryptionKey : Encryptor() (AsymmetricEncryptionKey, error)

struct JweRsaKeyEncryptionEncryptorImpl
JweRsaKeyEncryptionEncryptorImpl : recipientJwk jose.Jwk
JweRsaKeyEncryptionEncryptorImpl : recipientKey *rsa.PublicKey
JweRsaKeyEncryptionEncryptorImpl : cekAlg jose.Alg
JweRsaKeyEncryptionEncryptorImpl : NewJweRsaKeyEncryptionEncryptorImpl(recipient jose.Jwk, contentEncryptionAlg jose.Alg) (*JweRsaKeyEncryptionEncryptorImpl, error)
JweRsaKeyEncryptionEncryptorImpl : (e *JweRsaKeyEncryptionEncryptorImpl) Encrypt(plaintext, aad []byte) (string, error)

struct JweRsaKeyEncryptionDecryptorImpl
JweRsaKeyEncryptionDecryptorImpl : keystore AsymmetricDecryptionKeyStore
JweRsaKeyEncryptionDecryptorImpl : NewJweRsaKeyEncryptionDecryptorImpl(keystore AsymmetricDecryptionKeyStore) *JweRsaKeyEncryptionDecryptorImpl
JweRsaKeyEncryptionDecryptorImpl : (d *JweRsaKeyEncryptionDecryptorImpl) Decrypt(jwe string) (plaintext, aad []byte, err error)

struct AsymmetricDecryptionKeyImpl
AsymmetricDecryptionKeyImpl : kid string
AsymmetricDecryptionKeyImpl : ctx *crypto11.Context
AsymmetricDecryptionKeyImpl : key crypto11.SignerDecrypter
AsymmetricDecryptionKeyImpl : (a *AsymmetricDecryptionKey) Decrypt(_ jose.KeyOps, bytes []byte) ([]byte, error)
AsymmetricDecryptionKeyImpl : (a *AsymmetricDecryptionKey) Encryptor() (gose.AsymmetricEncryptionKey, error)

note right of AsymmetricDecryptionKeyImpl::key
Type is pkcs11PrivateKeyRSA
end note

note "JweRsaKeyEncryptionDecryptorImpl wraps a keystore\nwhich contains an AsymmetricDecryptionKey ID.\nThe method `Decrypt` is called for this key." as N1
JweRsaKeyEncryptionDecryptorImpl <.. N1
N1 .. AsymmetricDecryptionKey

note "`Encrypt` calls the standard Go crypto module for rsa encryption\nusing a given RSA public key." as N2
JweRsaKeyEncryptionEncryptorImpl <.. N2
N2 .. rsa

package crypto11 {


struct pkcs11PrivateKey implements Decrypter
struct pkcs11PrivateKey implements Signer
struct pkcs11PrivateKeyRSA extends pkcs11PrivateKey

Decrypter : Public() PublicKey
Decrypter : Decrypt(rand io.Reader, msg []byte, opts DecrypterOpts) (plaintext []byte, err error)

Signer : Public() PublicKey
Signer : Sign(rand io.Reader, digest []byte, opts SignerOpts) (signature []byte, err error)

pkcs11PrivateKey : pkcs11Object
pkcs11PrivateKey : pubKeyHandle pkcs11.ObjectHandle
pkcs11PrivateKey : pubKey crypto.PublicKey

struct pkcs11PrivateKeyRSA
pkcs11PrivateKeyRSA : pkcs11PrivateKey
pkcs11PrivateKeyRSA : (priv *pkcs11PrivateKeyRSA) Decrypt(rand io.Reader, ciphertext []byte, options crypto.DecrypterOpts) (plaintext []byte, err error)
pkcs11PrivateKeyRSA : (priv *pkcs11PrivateKeyRSA) Sign(rand io.Reader, digest []byte, opts crypto.SignerOpts) (signature []byte, err error)

}

note "AsymmetricDecryptionKeyImpl calls the Decrypt method\nfrom SignerDecrypter of type pkcs11PrivateKeyRSA" as N4
pkcs11PrivateKeyRSA <.. N4
N4 .. AsymmetricDecryptionKeyImpl



}


note "If the algorithm is RSA, P11 calls Encrypt() and Decrypt()\nfrom the JWE asymmetric key-based encryptors for RSA ciphers" as N3
gose <.. N3
N3 .. P11



@enduml
